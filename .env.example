DATABASE_URL="postgresql://heimdall:heimdall@localhost:5544/heimdall"

# GitHub PAT (contents:read, pull-requests:read, deployments:read) used for
# drift detection: open PRs against the prod branch, and production's latest
# GitHub Deployment vs. the branch tip. Stored per-site encrypted in the DB in
# later phases; used as a global fallback here for local dev.
GITHUB_TOKEN=""

# DataForSEO credentials for SEO rank tracking (Phase 1 SEO checks).
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# Discord webhook URL for alert notifications.
DISCORD_WEBHOOK_URL=""

# Symmetric key used to encrypt stored secrets (GitHub PATs, etc).
ENCRYPTION_KEY=""

# Auth.js (Google OAuth). Create credentials at
# https://console.cloud.google.com/apis/credentials — "Web application" type,
# OAuth consent screen set to "Internal". Authorized redirect URI:
# http://localhost:3000/api/auth/callback/google (local) and
# https://<prod-domain>/api/auth/callback/google (production).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Secret used by Auth.js to encrypt the session JWT. Separate from
# ENCRYPTION_KEY (that one encrypts stored integration secrets, not
# sessions). Generate with: npx auth secret
AUTH_SECRET=""

# Only Google accounts on this Workspace domain may sign in, checked against
# the verified `hd` claim on Google's ID token.
ALLOWED_EMAIL_DOMAIN="progani.com"
